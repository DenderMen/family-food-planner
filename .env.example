# ═══════════════════════════════════════════
# Family Dinner Planner – Environment Variables
# ═══════════════════════════════════════════
# Kopiere diese Datei zu .env.local und fülle die Werte aus.
# NIEMALS in Git committen! (.gitignore beachten)

# ─── Supabase ─────────────────────────────
# Erstelle ein Projekt auf https://supabase.com
# Settings → API → Project URL & anon key
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...dein-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...dein-service-role-key

# ─── Database (Supabase Postgres) ─────────
# Settings → Database → Connection string (Transaction mode)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─── Google Calendar API ──────────────────
# Erstelle ein Projekt auf https://console.cloud.google.com
# APIs → Google Calendar API aktivieren
# Credentials → OAuth 2.0 Client ID erstellen
GOOGLE_CLIENT_ID=deine-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-dein-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── Claude API (für Rezeptvorschläge) ────
# API Key von https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...dein-api-key

# ─── Google Gemini API (für Rezeptbilder) ─
# API Key von https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...dein-gemini-key

# ─── App ──────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
